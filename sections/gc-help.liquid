<section class="gc-help">
  <div class="gc-container">
    <header class="gc-help__head">
      <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="gc-display">{{ page.title | default: section.settings.heading }}</h1>
    </header>

    <div class="gc-help__block" id="gc-returns">
      <h2>{{ section.settings.returns_heading }}</h2>
      <div class="gc-help__returns">{{ section.settings.returns_copy }}</div>
    </div>

    <div class="gc-help__block" id="gc-faq">
      <h2>{{ section.settings.faq_heading }}</h2>
      <div class="gc-help__faq">
        {% for block in section.blocks %}
          <details class="gc-help__item" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <div class="gc-help__answer">{{ block.settings.answer }}</div>
          </details>
        {% else %}
          <div class="gc-help__returns">{{ section.settings.faq_copy }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .gc-help {
    background: var(--gc-card);
    padding: 112px 0;
  }

  .gc-help__head .gc-display {
    max-width: 900px;
    margin-top: 16px;
    font-size: clamp(56px, 8vw, 120px);
  }

  .gc-help__block {
    padding-top: 64px;
  }

  .gc-help__block > h2 {
    margin: 0 0 32px;
    color: var(--gc-muted);
    font-family: var(--gc-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.23em;
    line-height: 1.33;
    text-transform: uppercase;
  }

  .gc-help__returns {
    max-width: 760px;
    color: var(--gc-muted);
    font-size: 18px;
    line-height: 1.625;
  }

  .gc-help__faq {
    max-width: 760px;
    border-top: 1px solid var(--gc-border);
  }

  .gc-help__item {
    border-bottom: 1px solid var(--gc-border);
  }

  .gc-help__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    cursor: pointer;
    padding: 24px 0;
    color: var(--gc-ink);
    font-family: var(--gc-display);
    font-size: 20px;
    line-height: 1.2;
    list-style: none;
  }

  .gc-help__item summary::-webkit-details-marker {
    display: none;
  }

  .gc-help__item summary::after {
    content: "+";
    flex-shrink: 0;
    color: var(--gc-primary);
    font-size: 28px;
    font-weight: 300;
    line-height: 1;
  }

  .gc-help__item[open] summary::after {
    content: "\2212";
  }

  .gc-help__answer {
    max-width: 640px;
    padding: 0 0 24px;
    color: var(--gc-muted);
    font-size: 15px;
    line-height: 1.625;
  }

  @media (max-width: 620px) {
    .gc-help {
      padding: 80px 0;
    }

    .gc-help__item summary {
      font-size: 17px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius help",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help" },
    { "type": "text", "id": "heading", "label": "Fallback heading", "default": "Help" },
    { "type": "text", "id": "returns_heading", "label": "Returns heading", "default": "Returns & Cancellations" },
    { "type": "richtext", "id": "returns_copy", "label": "Returns copy", "default": "<p>Coming soon.</p>" },
    { "type": "text", "id": "faq_heading", "label": "FAQ heading", "default": "Frequently Asked Questions" },
    { "type": "richtext", "id": "faq_copy", "label": "FAQ placeholder copy", "default": "<p>Coming soon.</p>" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Genius help",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "<p>Orders ship within 1–2 business days and typically arrive in 3–5 days.</p>" } },
        { "type": "faq", "settings": { "question": "Is the coffee whole bean or ground?", "answer": "<p>Every bag ships whole bean by default. Choose a grind at checkout if you prefer.</p>" } },
        { "type": "faq", "settings": { "question": "How fresh is the coffee?", "answer": "<p>We roast to order in small batches and ship within days of roasting.</p>" } }
      ]
    }
  ]
}
{% endschema %}
