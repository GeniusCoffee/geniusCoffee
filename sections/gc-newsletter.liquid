<section class="gc-newsletter">
  <div class="gc-container gc-newsletter__grid">
    <div>
      <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="gc-display">{{ section.settings.heading }}</h2>
    </div>
    <div>
      <p class="gc-newsletter__copy">{{ section.settings.copy }}</p>
      {% form 'customer', class: 'gc-newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ 'newsletter.email' | t }}</label>
        <input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" placeholder="{{ section.settings.placeholder }}" autocorrect="off" autocapitalize="off" autocomplete="email" required>
        <button type="submit">{{ section.settings.button_label }}</button>
        {% if form.posted_successfully? %}
          <p class="gc-newsletter__message">{{ 'newsletter.success' | t }}</p>
        {% endif %}
        {% if form.errors %}
          <div class="gc-newsletter__message">{{ form.errors | default_errors }}</div>
        {% endif %}
      {% endform %}
      <p class="gc-newsletter__fineprint">{{ section.settings.fineprint }}</p>
    </div>
  </div>
</section>

{% stylesheet %}
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .gc-newsletter {
    background: var(--gc-primary);
    color: var(--gc-cream);
    padding: 80px 0;
  }

  .gc-newsletter__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 72px;
  }

  .gc-newsletter .gc-eyebrow {
    color: rgba(245, 240, 232, 0.58);
  }

  .gc-newsletter .gc-display {
    max-width: 380px;
    margin-top: 14px;
    font-size: clamp(42px, 4.6vw, 64px);
    line-height: 1;
  }

  .gc-newsletter__copy,
  .gc-newsletter__fineprint {
    margin: 0;
    color: rgba(245, 240, 232, 0.72);
  }

  .gc-newsletter__form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px;
    margin: 24px 0 10px;
  }

  .gc-newsletter__form input {
    min-height: 52px;
    border: 1px solid rgba(245, 240, 232, 0.3);
    background: rgba(245, 240, 232, 0.1);
    color: var(--gc-cream);
    padding: 0 20px;
  }

  .gc-newsletter__form input::placeholder {
    color: rgba(245, 240, 232, 0.64);
  }

  .gc-newsletter__form button {
    min-height: 52px;
    border: 1px solid var(--gc-ink);
    background: var(--gc-ink);
    color: var(--gc-cream);
    cursor: pointer;
    font-family: var(--gc-display);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.16em;
    padding: 0 28px;
    text-transform: uppercase;
  }

  .gc-newsletter__message {
    grid-column: 1 / -1;
    margin: 0;
  }

  @media (max-width: 760px) {
    .gc-newsletter {
      padding: 64px 0;
    }

    .gc-newsletter__grid,
    .gc-newsletter__form {
      grid-template-columns: 1fr;
    }

    .gc-newsletter__grid {
      gap: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the loop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fresh roasts, first." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "New lots, seasonal releases, and stories from origin delivered to your inbox." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "your@email.com" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "fineprint", "label": "Fine print", "default": "Unsubscribe anytime. We don't share your data." }
  ],
  "presets": [
    { "name": "Genius newsletter" }
  ]
}
{% endschema %}
