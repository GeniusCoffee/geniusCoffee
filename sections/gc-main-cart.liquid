<section class="gc-cart">
  <div class="gc-container">
    <h1 class="gc-display">{{ section.settings.heading | default: 'Your Bag' }}</h1>

    {% if cart.item_count == 0 %}
      <div class="gc-cart__empty">
        <p>{{ 'cart.empty' | t }}</p>
        <a class="gc-button gc-button--green" href="{{ routes.all_products_collection_url }}">
          {{ 'cart.continue_shopping' | t }}
          {% render 'gc-arrow-icon' %}
        </a>
      </div>
    {% else %}
      {% form 'cart', cart, class: 'gc-cart__form' %}
        <ul class="gc-cart__items">
          {% for item in cart.items %}
            <li class="gc-cart__item">
              <a class="gc-cart__media" href="{{ item.url }}">
                {% if item.image != blank %}
                  {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.title }}
                {% else %}
                  <span class="gc-cart__placeholder"></span>
                {% endif %}
              </a>
              <div class="gc-cart__info">
                <a class="gc-cart__title" href="{{ item.url }}">{{ item.product.title }}</a>
                {% unless item.product.has_only_default_variant %}
                  <p class="gc-cart__variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="gc-cart__price">{{ item.final_price | money_without_trailing_zeros }}</p>
              </div>
              <div class="gc-cart__controls">
                <label class="gc-visually-hidden" for="updates-{{ item.index | plus: 1 }}">{{ 'cart.quantity' | t }}</label>
                <input
                  id="updates-{{ item.index | plus: 1 }}"
                  class="gc-cart__qty"
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  inputmode="numeric"
                >
                {%- comment -%} ponytail: native GET remove; no JS needed {%- endcomment -%}
                <a class="gc-cart__remove" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
              </div>
              <p class="gc-cart__line-total">{{ item.final_line_price | money_without_trailing_zeros }}</p>
            </li>
          {% endfor %}
        </ul>

        <div class="gc-cart__footer">
          <div class="gc-cart__subtotal">
            <span>{{ 'cart.subtotal' | t }}</span>
            <strong>{{ cart.total_price | money_without_trailing_zeros }}</strong>
          </div>
          <div class="gc-cart__actions">
            <button class="gc-button gc-button--light" type="submit" name="update">{{ 'cart.update' | t }}</button>
            <button class="gc-button gc-button--green" type="submit" name="checkout">
              {{ 'cart.checkout' | t }}
              {% render 'gc-arrow-icon' %}
            </button>
          </div>
        </div>
      {% endform %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .gc-cart {
    background: var(--gc-card);
    padding: 80px 0 96px;
    min-height: 60vh;
  }

  .gc-cart .gc-display {
    font-size: clamp(48px, 4.7vw, 60px);
    line-height: 1;
    margin: 0 0 40px;
  }

  .gc-cart__empty {
    display: grid;
    gap: 24px;
    justify-items: start;
    color: var(--gc-muted);
  }

  .gc-cart__items {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--gc-border);
  }

  .gc-cart__item {
    display: grid;
    grid-template-columns: 96px 1fr auto auto;
    align-items: center;
    gap: 24px;
    border-bottom: 1px solid var(--gc-border);
    padding: 24px 0;
  }

  .gc-cart__media,
  .gc-cart__placeholder {
    display: block;
    width: 96px;
    height: 96px;
    background: var(--gc-cream);
    overflow: hidden;
  }

  .gc-cart__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gc-cart__title {
    font-family: var(--gc-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .gc-cart__variant {
    margin: 4px 0 0;
    color: var(--gc-muted);
    font-family: var(--gc-condensed);
    font-size: 13px;
    letter-spacing: 0.046em;
    text-transform: uppercase;
  }

  .gc-cart__price {
    margin: 8px 0 0;
    color: var(--gc-muted);
    font-size: 14px;
  }

  .gc-cart__controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .gc-cart__qty {
    width: 64px;
    min-height: 40px;
    border: 1px solid rgba(13, 13, 11, 0.19);
    background: transparent;
    color: var(--gc-ink);
    font-family: var(--gc-display);
    font-size: 16px;
    font-weight: 700;
    text-align: center;
    appearance: textfield;
  }

  .gc-cart__qty::-webkit-outer-spin-button,
  .gc-cart__qty::-webkit-inner-spin-button {
    margin: 0;
    appearance: none;
  }

  .gc-cart__remove {
    color: var(--gc-muted);
    font-family: var(--gc-condensed);
    font-size: 12px;
    letter-spacing: 0.046em;
    text-decoration: underline;
    text-transform: uppercase;
  }

  .gc-cart__line-total {
    margin: 0;
    font-family: var(--gc-display);
    font-size: 18px;
    font-weight: 900;
    text-align: right;
  }

  .gc-cart__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 40px;
  }

  .gc-cart__subtotal {
    display: flex;
    align-items: baseline;
    gap: 16px;
    font-family: var(--gc-display);
    text-transform: uppercase;
  }

  .gc-cart__subtotal span {
    color: var(--gc-muted);
    font-size: 13px;
    letter-spacing: 0.19em;
  }

  .gc-cart__subtotal strong {
    font-size: 28px;
    font-weight: 900;
  }

  .gc-cart__actions {
    display: flex;
    gap: 16px;
  }

  .gc-cart__actions .gc-button {
    min-height: 52px;
    padding: 16px 28px;
  }

  .gc-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .gc-cart__item {
      grid-template-columns: 72px 1fr auto;
      gap: 16px;
    }

    .gc-cart__media,
    .gc-cart__placeholder {
      width: 72px;
      height: 72px;
    }

    .gc-cart__line-total {
      grid-column: 2 / -1;
      text-align: left;
    }

    .gc-cart__footer {
      flex-direction: column;
      align-items: stretch;
    }

    .gc-cart__actions {
      flex-direction: column;
    }

    .gc-cart__actions .gc-button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius main cart",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Bag" }
  ],
  "presets": [
    { "name": "Genius main cart" }
  ]
}
{% endschema %}
