<section class="gc-brand-guide">
  <div class="gc-container">
    <header class="gc-brand-guide__hero">
      <div>
        <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="gc-display">{{ section.settings.heading }}</h1>
      </div>
      <p>{{ section.settings.copy }}</p>
    </header>

    <div class="gc-brand-guide__section">
      <h2>{{ section.settings.logo_heading }}</h2>
      <div class="gc-brand-guide__logo-grid">
        <div class="gc-brand-guide__logo-card gc-brand-guide__logo-card--light">
          {% render 'genius-logo' %}
        </div>
        <div class="gc-brand-guide__logo-card gc-brand-guide__logo-card--green">
          {% render 'genius-logo' %}
        </div>
        <div class="gc-brand-guide__logo-card gc-brand-guide__logo-card--forest">
          {% render 'genius-logo' %}
        </div>
      </div>
      <p class="gc-brand-guide__note">{{ section.settings.logo_note }}</p>
    </div>

    <div class="gc-brand-guide__section">
      <h2>{{ section.settings.palette_heading }}</h2>
      <div class="gc-brand-guide__palette">
        <article style="--swatch: var(--gc-primary);">
          <span></span>
          <strong>Genius Green</strong>
          <code>#007862</code>
          <small>--primary</small>
        </article>
        <article style="--swatch: var(--gc-forest);">
          <span></span>
          <strong>Forest</strong>
          <code>#1C3D30</code>
          <small>--secondary</small>
        </article>
        <article style="--swatch: var(--gc-cream);">
          <span></span>
          <strong>Cream</strong>
          <code>#F5F0E8</code>
          <small>--background</small>
        </article>
        <article style="--swatch: var(--gc-card);">
          <span></span>
          <strong>Card Cream</strong>
          <code>#EDE8DF</code>
          <small>--card</small>
        </article>
        <article style="--swatch: var(--gc-ink);">
          <span></span>
          <strong>Near Black</strong>
          <code>#0D0D0B</code>
          <small>--foreground</small>
        </article>
        <article style="--swatch: var(--gc-muted);">
          <span></span>
          <strong>Muted Stone</strong>
          <code>#6B6558</code>
          <small>--muted</small>
        </article>
      </div>
    </div>

    <div class="gc-brand-guide__section">
      <h2>{{ section.settings.type_heading }}</h2>
      <div class="gc-brand-guide__type-grid">
        <div>
          <small>Display &mdash; Barlow Black</small>
          <p class="gc-brand-guide__alphabet">ABCDEFGH<br>IJKLMNOP</p>
        </div>
        <div>
          <small>Body &mdash; DM Sans Regular / Light</small>
          <p>The quick brown fox jumps over the lazy dog. Genius Coffee believes that great coffee is a result of brilliant decisions at every single stage of the process, from seed selection to the final pour.</p>
        </div>
      </div>
    </div>

    <div class="gc-brand-guide__section">
      <div class="gc-brand-guide__scale">
        <span>Display / Hero</span>
        <strong>Genius</strong>
        <span>Heading 1</span>
        <h2>Small-Batch Roastery</h2>
        <span>Heading 2</span>
        <h3>Ethiopian Yirgacheffe</h3>
        <span>Body</span>
        <p>Notes of jasmine, bergamot, and stone fruit with a clean, bright finish.</p>
        <span>Label / Caption</span>
        <small>Direct Trade · 250g · Washed Process</small>
      </div>
    </div>

    <div class="gc-brand-guide__section">
      <h2>{{ section.settings.voice_heading }}</h2>
      <div class="gc-brand-guide__voice">
        <article>
          <h3>Direct</h3>
          <p>Say exactly what you mean. Short sentences. No padding. We respect our customers enough to be concise.</p>
          <blockquote>"Roasted Thursday. In your hands Monday."</blockquote>
        </article>
        <article>
          <h3>Curious</h3>
          <p>We ask good questions and share what we find. We explain why something tastes the way it does, not just what it does.</p>
          <blockquote>"Why does this taste like jasmine? The terroir at 2,100m does something extraordinary."</blockquote>
        </article>
        <article>
          <h3>Confident</h3>
          <p>We believe our coffee is exceptional. We earn the right to say so by showing our work: the farm, the data, the process.</p>
          <blockquote>"This is the best lot we've ever bought. Here's why."</blockquote>
        </article>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .gc-brand-guide {
    min-height: 1199px;
    background: var(--gc-card);
    padding: 112px 0;
  }

  .gc-brand-guide__hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 64px;
    border-bottom: 1px solid var(--gc-border);
    padding-bottom: 41px;
  }

  .gc-brand-guide__hero .gc-display {
    margin-top: 12px;
    font-size: 60px;
    line-height: 1;
  }

  .gc-brand-guide__hero > p {
    max-width: 320px;
    margin: 0;
    color: var(--gc-muted);
    font-size: 14px;
    line-height: 1.625;
  }

  .gc-brand-guide__section {
    padding-top: 64px;
  }

  .gc-brand-guide__section > h2,
  .gc-brand-guide__type-grid small,
  .gc-brand-guide__scale span {
    margin: 0 0 32px;
    color: var(--gc-muted);
    font-family: var(--gc-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.23em;
    line-height: 1.33;
    text-transform: uppercase;
  }

  .gc-brand-guide__logo-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .gc-brand-guide__logo-card {
    display: grid;
    min-height: 170px;
    place-items: center;
    border: 1px solid rgba(13, 13, 11, 0.07);
  }

  .gc-brand-guide__logo-card .gc-logo {
    pointer-events: none;
  }

  .gc-brand-guide__logo-card .gc-logo__top {
    font-size: 20px;
  }

  .gc-brand-guide__logo-card .gc-logo__bottom {
    font-size: 18px;
  }

  .gc-brand-guide__logo-card .gc-logo__mark {
    width: 14px;
    height: 14px;
  }

  .gc-brand-guide__logo-card--light {
    background: var(--gc-cream);
  }

  .gc-brand-guide__logo-card--green {
    background: var(--gc-primary);
  }

  .gc-brand-guide__logo-card--forest {
    background: var(--gc-forest);
  }

  .gc-brand-guide__logo-card--green .gc-logo__top,
  .gc-brand-guide__logo-card--green .gc-logo__bottom,
  .gc-brand-guide__logo-card--forest .gc-logo__top,
  .gc-brand-guide__logo-card--forest .gc-logo__bottom {
    color: var(--gc-cream);
  }

  .gc-brand-guide__logo-card--green .gc-logo__mark,
  .gc-brand-guide__logo-card--forest .gc-logo__mark {
    background: #e0eeea;
  }

  .gc-brand-guide__note {
    margin: 16px 0 0;
    color: var(--gc-muted);
    font-size: 13px;
    line-height: 1.625;
  }

  .gc-brand-guide__palette {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 12px;
  }

  .gc-brand-guide__palette article {
    min-width: 0;
  }

  .gc-brand-guide__palette span {
    display: block;
    aspect-ratio: 1;
    background: var(--swatch);
    border: 1px solid rgba(13, 13, 11, 0.07);
  }

  .gc-brand-guide__palette strong,
  .gc-brand-guide__palette code,
  .gc-brand-guide__palette small {
    display: block;
    margin-top: 8px;
    font-size: 13px;
    line-height: 1.33;
  }

  .gc-brand-guide__palette strong {
    font-family: var(--gc-display);
    font-weight: 600;
  }

  .gc-brand-guide__palette code {
    color: var(--gc-muted);
    font-family: Menlo, Consolas, monospace;
  }

  .gc-brand-guide__palette small {
    color: var(--gc-muted);
    font-family: var(--gc-condensed);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .gc-brand-guide__type-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    border-bottom: 1px solid var(--gc-border);
    padding-bottom: 64px;
  }

  .gc-brand-guide__type-grid small {
    display: block;
    margin-bottom: 24px;
  }

  .gc-brand-guide__alphabet {
    margin: 0;
    font-family: var(--gc-display);
    font-size: 48px;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    text-transform: uppercase;
  }

  .gc-brand-guide__type-grid p:not(.gc-brand-guide__alphabet) {
    max-width: 520px;
    margin: 0;
    color: var(--gc-muted);
    font-size: 14px;
    line-height: 1.625;
  }

  .gc-brand-guide__scale {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 12px 32px;
    border-bottom: 1px solid var(--gc-border);
    padding-bottom: 64px;
  }

  .gc-brand-guide__scale span {
    margin: 0;
    padding-top: 10px;
  }

  .gc-brand-guide__scale strong {
    font-family: var(--gc-display);
    font-size: 96px;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .gc-brand-guide__scale h2,
  .gc-brand-guide__scale h3,
  .gc-brand-guide__scale p,
  .gc-brand-guide__scale small {
    margin: 0;
  }

  .gc-brand-guide__scale h2,
  .gc-brand-guide__scale h3 {
    font-family: var(--gc-display);
    line-height: 1;
  }

  .gc-brand-guide__scale h2 {
    font-size: 40px;
  }

  .gc-brand-guide__scale h3 {
    font-size: 24px;
  }

  .gc-brand-guide__scale p {
    color: var(--gc-muted);
    font-size: 14px;
  }

  .gc-brand-guide__scale small {
    font-family: var(--gc-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .gc-brand-guide__voice {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--gc-border);
  }

  .gc-brand-guide__voice article {
    min-height: 180px;
    border-right: 1px solid var(--gc-border);
    padding: 32px 32px 0 0;
  }

  .gc-brand-guide__voice article + article {
    padding-left: 32px;
  }

  .gc-brand-guide__voice article:last-child {
    border-right: 0;
  }

  .gc-brand-guide__voice h3 {
    margin: 0 0 12px;
    font-family: var(--gc-display);
    font-size: 20px;
    line-height: 1;
    text-transform: uppercase;
  }

  .gc-brand-guide__voice p,
  .gc-brand-guide__voice blockquote {
    margin: 0;
    color: var(--gc-muted);
    font-size: 13px;
    line-height: 1.625;
  }

  .gc-brand-guide__voice blockquote {
    margin-top: 16px;
    border-left: 2px solid var(--gc-primary);
    color: var(--gc-ink);
    font-style: italic;
    padding-left: 16px;
  }

  @media (max-width: 900px) {
    .gc-brand-guide__hero,
    .gc-brand-guide__type-grid,
    .gc-brand-guide__voice {
      grid-template-columns: 1fr;
    }

    .gc-brand-guide__hero {
      display: grid;
      align-items: start;
      gap: 24px;
    }

    .gc-brand-guide__palette {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .gc-brand-guide__voice article,
    .gc-brand-guide__voice article + article {
      border-right: 0;
      border-bottom: 1px solid var(--gc-border);
      padding: 32px 0;
    }

    .gc-brand-guide__voice article:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 620px) {
    .gc-brand-guide {
      padding: 80px 0;
    }

    .gc-brand-guide__hero .gc-display {
      font-size: 48px;
    }

    .gc-brand-guide__logo-grid,
    .gc-brand-guide__palette {
      grid-template-columns: 1fr;
    }

    .gc-brand-guide__scale {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .gc-brand-guide__scale strong {
      font-size: 64px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius brand guide",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Brand System" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Style Guide" },
    { "type": "textarea", "id": "copy", "label": "Intro copy", "default": "Brand guidelines for Genius Coffee. Use these elements consistently across all touchpoints." },
    { "type": "text", "id": "logo_heading", "label": "Logo heading", "default": "Logo & Mark" },
    { "type": "textarea", "id": "logo_note", "label": "Logo note", "default": "The Genius mark always consists of the two-line wordmark with the square accent between Genius and Coffee. Minimum size: 80px wide. Clear space: equal to the height of the square accent on all sides." },
    { "type": "text", "id": "palette_heading", "label": "Palette heading", "default": "Colour Palette" },
    { "type": "text", "id": "type_heading", "label": "Typography heading", "default": "Typography" },
    { "type": "text", "id": "voice_heading", "label": "Voice heading", "default": "Brand Voice" }
  ],
  "presets": [
    { "name": "Genius brand guide" }
  ]
}
{% endschema %}
