<section class="gc-roasts">
  <div class="gc-container">
    <div class="gc-roasts__header">
      <div>
        <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="gc-display">{{ section.settings.heading }}</h2>
      </div>
      <a class="gc-roasts__link" href="{{ section.settings.link_url }}">
        {{ section.settings.link_label }}
        {% render 'gc-arrow-icon' %}
      </a>
    </div>
    <div class="gc-roasts__grid">
      {%- comment -%} ponytail: tile markup mirrors snippets/gc-shop-category.liquid; .gc-shop-tile CSS is globally bundled from sections/gc-collection-shop.liquid {%- endcomment -%}
      {% for product in collections['highlighted'].products limit: 3 %}
        {% assign selected_variant = product.selected_or_first_available_variant %}
        <article class="gc-shop-tile">
          <a class="gc-shop-tile__head" href="{{ product.url }}">
            <span>
              <strong>{{ product.title }}</strong>
            </span>
            <b>{{ selected_variant.price | money_without_trailing_zeros }}</b>
          </a>
          <a class="gc-shop-tile__image" href="{{ product.url }}">
            {% if product.featured_image != blank %}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title, class: 'gc-shop-tile__image-primary' }}
              {% if product.images.size > 1 %}
                {{ product.images[1] | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title, class: 'gc-shop-tile__image-secondary' }}
              {% endif %}
            {% else %}
              <span>Coffee</span>
            {% endif %}
          </a>
        </article>
      {% else %}
        <p class="gc-roasts__empty">No highlighted roasts yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .gc-roasts {
    border-top: 1px solid var(--gc-border);
    background: var(--gc-card);
    padding: 64px 0;
  }

  .gc-roasts__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 48px;
  }

  .gc-roasts__header .gc-display {
    margin-top: 12px;
    font-size: clamp(46px, 5vw, 72px);
    line-height: 1;
  }

  .gc-roasts__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--gc-primary);
    font-family: var(--gc-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .gc-roasts__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* Reuse shop-page tiles (.gc-shop-tile, styled globally); card ends at the image, no chin. */
  .gc-roasts__grid .gc-shop-tile {
    min-height: 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    height: 500px;
  }

  .gc-roasts__grid .gc-shop-tile__image {
    flex: 1;
    min-height: 0;
  }

  .gc-roasts__grid .gc-shop-tile__head {
    align-items: center;
  }

  .gc-roasts__grid .gc-shop-tile__head strong,
  .gc-roasts__grid .gc-shop-tile__head b {
    font-size: 26px;
  }

  .gc-roasts__grid .gc-shop-tile__head span {
    display: block;
    min-width: 0;
  }

  .gc-roasts__grid .gc-shop-tile__head strong {
    display: block;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-weight: 300;
    font-size: 20px;
  }

  .gc-roasts__grid .gc-shop-tile__head b {
    align-self: stretch;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--gc-forest);
    font-weight: 400;
    font-size: 20px;
  }

  .gc-roasts__empty {
    grid-column: 1 / -1;
    padding: 48px 24px;
    color: var(--gc-ink);
    font-family: var(--gc-condensed);
    letter-spacing: 0.046em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .gc-roasts__grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .gc-roasts__grid .gc-shop-tile {
      height: auto;
    }

    .gc-roasts__grid .gc-shop-tile__image {
      flex: none;
      aspect-ratio: 1;
    }
  }

  @media (max-width: 760px) {
    .gc-roasts {
      padding: 64px 0;
    }

    .gc-roasts__header {
      display: block;
      margin-bottom: 48px;
    }

    .gc-roasts__header .gc-display {
      font-size: 48px;
    }

    .gc-roasts__link {
      display: inline-flex;
      margin-top: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius featured roasts",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Current Offerings" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Roasts" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View All" },
    { "type": "url", "id": "link_url", "label": "Link URL", "default": "/collections/all" }
  ],
  "blocks": [
    {
      "type": "roast",
      "name": "Roast card",
      "settings": [
        { "type": "product", "id": "product", "label": "Shopify product" },
        { "type": "checkbox", "id": "highlighted", "label": "Highlight card", "default": false },
        { "type": "checkbox", "id": "dark", "label": "Dark (forest) card", "default": false },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Signature" },
        { "type": "text", "id": "title", "label": "Roast title", "default": "Light Roast" },
        { "type": "text", "id": "origin", "label": "Origin", "default": "Ethiopian Yirgacheffe" },
