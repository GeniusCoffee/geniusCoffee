<section class="gc-roasts">
  <div class="gc-container">
    <div class="gc-roasts__header">
      <div>
        <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="gc-display">{{ section.settings.heading }}</h2>
      </div>
      <a class="gc-roasts__link" href="{{ section.settings.link_url }}">
        {{ section.settings.link_label }}
        {% render 'gc-arrow-icon' %}
      </a>
    </div>
    <div class="gc-roasts__grid">
      {% for block in section.blocks %}
        {% render 'gc-product-card',
          product: block.settings.product,
          badge: block.settings.badge,
          title: block.settings.title,
          origin: block.settings.origin,
          price: block.settings.price,
          process: block.settings.process,
          weight: block.settings.weight,
          elevation: block.settings.elevation,
          notes: block.settings.notes,
          highlighted: block.settings.highlighted,
          dark: block.settings.dark,
          show_image: false
        %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .gc-roasts {
    border-top: 1px solid var(--gc-border);
    background: var(--gc-card);
    padding: 64px 0;
  }

  .gc-roasts__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 48px;
  }

  .gc-roasts__header .gc-display {
    margin-top: 12px;
    font-size: clamp(46px, 5vw, 72px);
    line-height: 1;
  }

  .gc-roasts__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--gc-primary);
    font-family: var(--gc-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .gc-roasts__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-right: 1px solid var(--gc-border);
    border-bottom: 1px solid var(--gc-border);
    border-left: 1px solid var(--gc-border);
  }

  .gc-roasts__grid .gc-product-card {
    border-right: 0;
    border-bottom: 0;
    border-left: 0;
  }

  @media (max-width: 980px) {
    .gc-roasts__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .gc-roasts {
      padding: 64px 0;
    }

    .gc-roasts__header {
      display: block;
      margin-bottom: 48px;
    }

    .gc-roasts__header .gc-display {
      font-size: 48px;
    }

    .gc-roasts__link {
      display: inline-flex;
      margin-top: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius featured roasts",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Current Offerings" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Roasts" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View All" },
    { "type": "url", "id": "link_url", "label": "Link URL", "default": "/collections/all" }
  ],
  "blocks": [
    {
      "type": "roast",
      "name": "Roast card",
      "settings": [
        { "type": "product", "id": "product", "label": "Shopify product" },
        { "type": "checkbox", "id": "highlighted", "label": "Highlight card", "default": false },
        { "type": "checkbox", "id": "dark", "label": "Dark (forest) card", "default": false },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Signature" },
        { "type": "text", "id": "title", "label": "Roast title", "default": "Light Roast" },
        { "type": "text", "id": "origin", "label": "Origin", "default": "Ethiopian Yirgacheffe" },
        { "type": "text", "id": "price", "label": "Fallback price", "default": "GBP 14" },
        { "type": "text", "id": "process", "label": "Process", "default": "Washed" },
        { "type": "text", "id": "weight", "label": "Weight", "default": "250g" },
        { "type": "text", "id": "elevation", "label": "Elevation", "default": "1,800-2,200m" },
        { "type": "textarea", "id": "notes", "label": "Notes", "default": "Jasmine, Bergamot, Stone Fruit" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Genius featured roasts",
      "blocks": [
        {
          "type": "roast",
          "settings": {
            "badge": "Signature",
            "title": "Light Roast",
            "origin": "Ethiopian Yirgacheffe",
            "process": "Washed",
            "weight": "250g",
            "elevation": "1,800-2,200m",
            "notes": "Jasmine, Bergamot, Stone Fruit"
          }
        },
        {
          "type": "roast",
          "settings": {
            "badge": "Bestseller",
            "title": "Medium Roast",
            "origin": "Colombian Huila",
            "process": "Natural",
            "weight": "250g",
            "elevation": "1,600-1,900m",
            "notes": "Brown Sugar, Hazelnut, Red Apple",
            "highlighted": true
          }
        },
        {
          "type": "roast",
          "settings": {
            "badge": "New",
            "title": "Darker Roast",
            "origin": "Sumatra Mandheling",
            "process": "Wet-Hulled",
            "weight": "250g",
            "elevation": "1,200-1,500m",
            "notes": "Dark Chocolate, Cedar, Molasses",
            "dark": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
