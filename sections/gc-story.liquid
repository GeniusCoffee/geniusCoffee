<section class="gc-story">
  <div class="gc-container gc-story__grid">
    <div class="gc-story__copy">
      <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="gc-display">{{ section.settings.heading }} <strong>{{ section.settings.highlight }}</strong></h2>
      <div class="gc-story__rte">{{ section.settings.copy }}</div>
    </div>
    <div class="gc-story__media" style="--story-image-opacity: {{ section.settings.image_opacity | divided_by: 100.0 }};">
      <div class="gc-story__placeholder"></div>
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'gc-story__image', loading: 'lazy', alt: section.settings.heading }}
      {% endif %}
      <div class="gc-story__stat">
        <strong>{{ section.settings.stat_value }}</strong>
        <span>{{ section.settings.stat_label }}</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .gc-story {
    background: var(--gc-forest);
    color: var(--gc-cream);
    padding: 112px 0;
  }

  .gc-story__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 568px);
    align-items: center;
    gap: 64px;
  }

  .gc-story .gc-eyebrow,
  .gc-story .gc-display strong {
    color: var(--gc-primary);
  }

  .gc-story .gc-display {
    max-width: 520px;
    margin-top: 18px;
    font-size: clamp(48px, 5vw, 72px);
  }

  .gc-story__rte {
    max-width: 560px;
    margin: 28px 0 32px;
    color: rgba(245, 240, 232, 0.72);
  }

  .gc-story__media {
    position: relative;
  }

  .gc-story__placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(135deg, rgba(245, 240, 232, 0.22), rgba(0, 120, 98, 0.45));
  }

  .gc-story__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: var(--story-image-opacity, 1);
  }

  .gc-story__stat {
    position: absolute;
    z-index: 1;
    bottom: -24px;
    left: -24px;
    display: grid;
    min-width: 132px;
    background: var(--gc-primary);
    color: var(--gc-cream);
    padding: 16px;
  }

  .gc-story__stat strong {
    font-family: var(--gc-display);
    font-size: 32px;
    line-height: 1;
  }

  .gc-story__stat span {
    font-family: var(--gc-display);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .gc-story__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .gc-story__media {
      max-width: 520px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Coffee roasted" },
    { "type": "text", "id": "highlight", "label": "Highlight", "default": "smarter." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>Genius Coffee was founded with one question: what if every decision in the supply chain was better? From sourcing to roasting to dispatch, we optimise for transparency, quality, and consistency.</p><p>We source exclusively from farms we visit. We roast in small batches and ship fresh to order.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "range", "id": "image_opacity", "label": "Image opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "text", "id": "stat_value", "label": "Stat value", "default": "100%" },
    { "type": "text", "id": "stat_label", "label": "Stat label", "default": "Direct Trade" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read More" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Genius story" }
  ]
}
{% endschema %}
