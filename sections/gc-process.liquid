<section class="gc-process">
  <div class="gc-container">
    <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="gc-display">{{ section.settings.heading }}</h2>
    <div class="gc-process__grid">
      {% for block in section.blocks %}
        <article class="gc-process__step" {{ block.shopify_attributes }}>
          <span>{{ block.settings.number }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.copy }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .gc-process {
    background: var(--gc-cream);
    padding: 96px 0 112px;
  }

  .gc-process .gc-display {
    max-width: 560px;
    margin-top: 16px;
    font-size: clamp(48px, 5.4vw, 76px);
    line-height: 1;
  }

  .gc-process__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 64px;
    border-top: 1px solid var(--gc-border);
  }

  .gc-process__step {
    padding: 32px 40px 0 0;
    border-right: 1px solid var(--gc-border);
  }

  .gc-process__step + .gc-process__step {
    padding-left: 40px;
  }

  .gc-process__step:last-child {
    border-right: 0;
  }

  .gc-process__step span {
    color: rgba(0, 120, 98, 0.24);
    font-family: var(--gc-display);
    font-size: 48px;
    font-weight: 900;
    line-height: 1;
  }

  .gc-process__step h3 {
    margin: 24px 0 12px;
    font-family: var(--gc-display);
    font-size: 28px;
    line-height: 1;
    text-transform: uppercase;
  }

  .gc-process__step p {
    max-width: 320px;
    margin: 0;
    color: var(--gc-muted);
    font-size: 14px;
  }

  @media (max-width: 760px) {
    .gc-process__grid {
      grid-template-columns: 1fr;
      margin-top: 48px;
    }

    .gc-process__step,
    .gc-process__step + .gc-process__step {
      border-right: 0;
      border-bottom: 1px solid var(--gc-border);
      padding: 32px 0;
    }

    .gc-process__step:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius process",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From farm to cup." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Source" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "We build direct relationships with farmers across Ethiopia, Colombia, and Indonesia, paying above Fairtrade for exceptional lots." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Genius process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "heading": "Source",
            "copy": "We build direct relationships with farmers across Ethiopia, Colombia, and Indonesia, paying above Fairtrade for exceptional lots."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "heading": "Roast",
            "copy": "Every batch is roasted in small 15kg drums at our London roastery."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "heading": "Ship",
            "copy": "Orders roasted fresh to order, dispatched within 48 hours."
          }
        }
      ]
    }
  ]
}
{% endschema %}
