<section class="gc-contact">
  <div class="gc-container">
    <header class="gc-contact__head">
      <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="gc-display">{{ page.title | default: section.settings.heading }}</h1>
      {% if section.settings.copy != blank %}
        <div class="gc-contact__copy">{{ section.settings.copy }}</div>
      {% endif %}
    </header>

    {% form 'contact', class: 'gc-contact__form' %}
      {% if form.posted_successfully? %}
        <p class="gc-contact__message gc-contact__message--success">{{ section.settings.success_message }}</p>
      {% endif %}
      {% if form.errors %}
        <div class="gc-contact__message gc-contact__message--error">{{ form.errors | default_errors }}</div>
      {% endif %}

      <div class="gc-contact__row">
        <label for="ContactName-{{ section.id }}">Name</label>
        <input type="text" id="ContactName-{{ section.id }}" name="contact[name]" autocomplete="name">
      </div>
      <div class="gc-contact__row">
        <label for="ContactEmail-{{ section.id }}">Email *</label>
        <input type="email" id="ContactEmail-{{ section.id }}" name="contact[email]" value="{{ form.email }}" autocorrect="off" autocapitalize="off" autocomplete="email" required>
      </div>
      <div class="gc-contact__row">
        <label for="ContactPhone-{{ section.id }}">Phone</label>
        <input type="tel" id="ContactPhone-{{ section.id }}" name="contact[phone]" autocomplete="tel">
      </div>
      <div class="gc-contact__row">
        <label for="ContactOrder-{{ section.id }}">Order number</label>
        <input type="text" id="ContactOrder-{{ section.id }}" name="contact[order_number]">
      </div>
      <div class="gc-contact__row">
        <label for="ContactBody-{{ section.id }}">Message</label>
        <textarea id="ContactBody-{{ section.id }}" name="contact[body]" rows="6">{{ form.body }}</textarea>
      </div>
      <button type="submit" class="gc-contact__submit">{{ section.settings.button_label }}</button>
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .gc-contact {
    background: var(--gc-card);
    padding: 112px 0;
  }

  .gc-contact__head .gc-display {
    max-width: 900px;
    margin-top: 16px;
    font-size: clamp(56px, 8vw, 120px);
  }

  .gc-contact__copy {
    max-width: 640px;
    margin-top: 24px;
    color: var(--gc-muted);
    font-size: 18px;
    line-height: 1.625;
  }

  .gc-contact__form {
    display: grid;
    gap: 20px;
    max-width: 640px;
    margin-top: 48px;
  }

  .gc-contact__row {
    display: grid;
    gap: 8px;
  }

  .gc-contact__row label {
    color: var(--gc-muted);
    font-family: var(--gc-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .gc-contact__row input,
  .gc-contact__row textarea {
    width: 100%;
    border: 1px solid var(--gc-border);
    background: var(--gc-cream);
    color: var(--gc-ink);
    font-family: var(--gc-body);
    font-size: 16px;
    padding: 14px 16px;
  }

  .gc-contact__row input {
    min-height: 52px;
  }

  .gc-contact__row textarea {
    resize: vertical;
  }

  .gc-contact__submit {
    justify-self: start;
    min-height: 52px;
    border: 1px solid var(--gc-ink);
    background: var(--gc-ink);
    color: var(--gc-cream);
    cursor: pointer;
    font-family: var(--gc-display);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.16em;
    padding: 0 32px;
    text-transform: uppercase;
  }

  .gc-contact__message {
    margin: 0;
    padding: 16px 20px;
    font-size: 15px;
  }

  .gc-contact__message--success {
    background: var(--gc-primary);
    color: var(--gc-cream);
  }

  .gc-contact__message--error {
    border: 1px solid var(--gc-border);
    color: var(--gc-ink);
  }

  @media (max-width: 620px) {
    .gc-contact {
      padding: 80px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius contact",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Get in touch" },
    { "type": "text", "id": "heading", "label": "Fallback heading", "default": "Contact" },
    { "type": "richtext", "id": "copy", "label": "Intro copy", "default": "<p>Questions about an order, wholesale, or just want to talk coffee? Send us a message and we'll get back to you within 1–2 business days.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send message" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for reaching out — we'll be in touch soon." }
  ],
  "presets": [
    { "name": "Genius contact" }
  ]
}
{% endschema %}
