<section class="gc-hero{% if section.settings.image != blank %} gc-hero--has-image{% endif %}" style="--hero-opacity: {{ section.settings.image_opacity | divided_by: 100.0 }}; --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};">
  {% if section.settings.image != blank %}
    {{ section.settings.image | image_url: width: 2400 | image_tag: class: 'gc-hero__image', loading: 'eager', alt: section.settings.heading }}
  {% endif %}
  <div class="gc-container gc-hero__inner">
    <p class="gc-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="gc-display gc-hero__title">
      <span>{{ section.settings.heading }}</span>
      <strong>{{ section.settings.highlight }}</strong>
      <span>{{ section.settings.heading_after }}</span>
    </h1>
  </div>
</section>

{% stylesheet %}
  .gc-hero {
    position: relative;
    overflow: hidden;
    background: var(--gc-card);
  }

  .gc-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: var(--hero-opacity);
  }

  .gc-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(245, 240, 232, var(--overlay-opacity));
  }

  .gc-container.gc-hero__inner {
    position: relative;
    z-index: 1;
    padding-block: 128px;
  }

  .gc-hero__title {
    max-width: 1200px;
    margin-top: 32px;
    font-size: clamp(96px, 9.2vw, 200px);
    line-height: 0.88;
  }

  .gc-hero__title > span,
  .gc-hero__title > strong {
    display: block;
  }

  .gc-hero__title > span {
    width: min-content;
   }

  @media (max-width: 760px) {
    .gc-hero__title {
      font-size: clamp(64px, 18vw, 96px);
      line-height: 0.9;
    }

  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genius hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "image_opacity", "label": "Image opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 35 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 55 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Small-Batch · London Roastery · Est. 2024" },
    { "type": "text", "id": "heading", "label": "Heading before highlight", "default": "Think" },
    { "type": "text", "id": "highlight", "label": "Highlighted heading", "default": "Better." },
    { "type": "text", "id": "heading_after", "label": "Heading after highlight", "default": "Drink Better." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Genius Coffee sources and roasts exceptional single-origin beans. We believe great coffee starts with great thinking - about the crop, the roast, and the cup." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop All Roasts" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Our Story" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" }
  ],
  "presets": [
    { "name": "Genius hero" }
  ]
}
{% endschema %}
