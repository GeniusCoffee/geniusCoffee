{% comment %}
  One shop category: aside heading/copy + product grid.
  Params: id, heading, copy, label (image placeholder), products (pre-filtered list)
{% endcomment %}
<section id="{{ id }}" class="gc-shop-products">
  <div class="gc-container gc-shop-products__layout">
    <aside>
      <h2 class="gc-display">{{ heading }}</h2>
      <p>{{ copy }}</p>
    </aside>
    <div class="gc-shop-products__grid">
      {% for product in products limit: 12 %}
        {% liquid
          assign selected_variant = product.selected_or_first_available_variant
          assign product_notes = product.description | strip_html | truncate: 42
        %}
        <article class="gc-shop-tile">
          <a class="gc-shop-tile__head" href="{{ product.url }}">
            <span>
              <strong>{{ product.title }}</strong>
              <small>{{ product.vendor }}</small>
            </span>
            <b>{{ selected_variant.price | money_without_trailing_zeros }}</b>
          </a>
          <a class="gc-shop-tile__image" href="{{ product.url }}">
            {% if product.featured_image != blank %}
              {{ product.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title }}
            {% else %}
              <span>{{ label }}</span>
            {% endif %}
          </a>
          <p>{{ product_notes }}</p>
        </article>
      {% else %}
        {% if demo %}
          {% comment %} ponytail: sample tiles for the pre-launch client preview; delete this block once real products exist {% endcomment %}
          {% assign demo_url = collection.products.first.url | default: routes.collections_url %}
          <article class="gc-shop-tile">
            <a class="gc-shop-tile__head" href="{{ demo_url }}">
              <span><strong>Light Roast</strong><small>Ethiopian Yirgacheffe</small></span>
              <b>£14</b>
            </a>
            <a class="gc-shop-tile__image" href="{{ demo_url }}"><span>{{ label }}</span></a>
            <p>Jasmine · Bergamot · Stone Fruit</p>
          </article>
          <article class="gc-shop-tile">
            <a class="gc-shop-tile__head" href="{{ demo_url }}">
              <span><strong>Medium Roast</strong><small>Colombian Huila</small></span>
              <b>£14</b>
            </a>
            <a class="gc-shop-tile__image" href="{{ demo_url }}"><span>{{ label }}</span></a>
            <p>Brown Sugar · Hazelnut · Red Apple</p>
          </article>
          <article class="gc-shop-tile">
            <a class="gc-shop-tile__head" href="{{ demo_url }}">
              <span><strong>Darker Roast</strong><small>Sumatra Mandheling</small></span>
              <b>£14</b>
            </a>
            <a class="gc-shop-tile__image" href="{{ demo_url }}"><span>{{ label }}</span></a>
            <p>Dark Chocolate · Cedar · Molasses</p>
          </article>
        {% else %}
          <p class="gc-shop-products__empty">Coming soon.</p>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
