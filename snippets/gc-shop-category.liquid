{% comment %}
  One shop category: aside heading/copy + product grid.
  Params: id, heading, copy, label (image placeholder), match_type (case-insensitive product.type), collection
{% endcomment %}
{% assign type_match = match_type | downcase %}
<section id="{{ id }}" class="gc-shop-products">
  <div class="gc-container gc-shop-products__layout">
    <aside>
      <h2 class="gc-display">{{ heading }}</h2>
      <p>{{ copy }}</p>
    </aside>
    <div class="gc-shop-products__grid">
      {% assign shown = 0 %}
      {% for product in collection.products %}
        {% assign ptype = product.type | downcase %}
        {% if ptype != type_match %}{% continue %}{% endif %}
        {% if shown >= 12 %}{% break %}{% endif %}
        {% assign shown = shown | plus: 1 %}
        {% liquid
          assign selected_variant = product.selected_or_first_available_variant
          assign product_notes = product.description | strip_html | truncate: 42
        %}
        <article class="gc-shop-tile">
          <a class="gc-shop-tile__head" href="{{ product.url }}">
            <span>
              <strong>{{ product.title }}</strong>
              <small>{{ product.vendor }}</small>
            </span>
            <b>{{ selected_variant.price | money_without_trailing_zeros }}</b>
          </a>
          <a class="gc-shop-tile__image" href="{{ product.url }}">
            {% if product.featured_image != blank %}
              {{ product.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title, class: 'gc-shop-tile__image-primary' }}
              {% if product.images.size > 1 %}
                {{ product.images[1] | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title, class: 'gc-shop-tile__image-secondary' }}
              {% endif %}
            {% else %}
              <span>{{ label }}</span>
            {% endif %}
          </a>
          <p>{{ product_notes }}</p>
        </article>
      {% endfor %}
      {% if shown == 0 %}
        <p class="gc-shop-products__empty">Coming soon.</p>
      {% endif %}
    </div>
  </div>
</section>
