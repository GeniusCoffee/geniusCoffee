<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}{% if current_tags %} - {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} - Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}</title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    {% # theme-check-disable RemoteAsset %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@600;700;800;900&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet">
    {% # theme-check-enable RemoteAsset %}
    {{ content_for_header }}
    <style>
      :root {
        --gc-primary: #007862;
        --gc-forest: #1c3d30;
        --gc-cream: #f5f0e8;
        --gc-card: #ede8df;
        --gc-ink: #0d0d0b;
        --gc-muted: #6b6558;
        --gc-border: rgba(13, 13, 11, 0.08);
        --gc-display: "Barlow", "Arial Black", Impact, sans-serif;
        --gc-body: "DM Sans", Inter, system-ui, sans-serif;
        --gc-condensed: "Barlow Condensed", "Arial Narrow", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--gc-cream);
        color: var(--gc-ink);
        font-family: var(--gc-body);
        font-size: 16px;
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
      }

      button,
      input,
      textarea,
      select {
        font: inherit;
      }

      .gc-container {
        width: min(100%, 1280px);
        margin: 0 auto;
        padding: 0 40px;
      }

      .gc-eyebrow {
        margin: 0;
        color: var(--gc-primary);
        font-family: var(--gc-display);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.28em;
        line-height: 1.35;
        text-transform: uppercase;
      }

      .gc-display {
        margin: 0;
        font-family: var(--gc-display);
        font-weight: 900;
        letter-spacing: -0.02em;
        line-height: 0.96;
        text-transform: uppercase;
      }

      .gc-display strong {
        color: var(--gc-primary);
        font: inherit;
      }

      .gc-muted {
        color: var(--gc-muted);
      }

      .gc-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
        min-height: 40px;
        border: 1px solid var(--gc-ink);
        background: var(--gc-ink);
        color: var(--gc-cream);
        cursor: pointer;
        font-family: var(--gc-display);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.1em;
        line-height: 1;
        padding: 10px 20px;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .gc-button:focus-visible,
      .gc-nav a:focus-visible,
      .gc-logo:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 4px;
      }

      .gc-button--light {
        background: transparent;
        color: var(--gc-ink);
      }

      .gc-button--green {
        border-color: var(--gc-primary);
        background: var(--gc-primary);
        color: var(--gc-cream);
      }

      .gc-arrow-icon {
        width: 1em;
        height: 1em;
        flex: 0 0 auto;
      }

      .gc-arrow-icon--left {
        transform: rotate(180deg);
      }

      .gc-site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid var(--gc-border);
        background: var(--gc-cream);
      }

      .gc-site-header__inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        min-height: 64px;
        gap: 32px;
      }

      .gc-logo {
        display: inline-flex;
        flex-direction: column;
        font-family: var(--gc-display);
        font-weight: 900;
        line-height: 0.9;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .gc-logo__top {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        color: var(--gc-ink);
        font-size: 14px;
        letter-spacing: -0.025em;
      }

      .gc-logo__mark {
        width: 7px;
        height: 7px;
        background: var(--gc-primary);
      }

      .gc-logo__bottom {
        color: var(--gc-primary);
        font-size: 13px;
        letter-spacing: 0.2em;
      }

      .gc-nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 32px;
        font-family: var(--gc-display);
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .gc-nav a[aria-current="page"] {
        color: var(--gc-primary);
      }

      .gc-header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 20px;
      }

      .gc-header-cart,
      .gc-header-account {
        position: relative;
        display: inline-flex;
        align-items: center;
        color: var(--gc-ink);
      }

      .gc-cart-icon,
      .gc-account-icon {
        width: 22px;
        height: 22px;
      }

      .gc-header-cart__count {
        position: absolute;
        top: -6px;
        right: -8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        border-radius: 999px;
        background: var(--gc-primary);
        color: var(--gc-cream);
        font-family: var(--gc-display);
        font-size: 10px;
        font-weight: 700;
        line-height: 1;
      }

      .gc-menu-toggle {
        display: none;
      }

      main {
        min-height: 60vh;
      }

      @media (max-width: 760px) {
        .gc-container {
          width: min(100%, 560px);
          padding: 0 24px;
        }

        .gc-site-header__inner {
          grid-template-columns: 1fr auto;
        }

        .gc-nav,
        .gc-header-actions {
          display: none;
        }

        .gc-menu-toggle {
          display: inline-flex;
          width: 22px;
          height: 18px;
          border: 0;
          background: linear-gradient(var(--gc-ink), var(--gc-ink)) left center / 22px 2px no-repeat;
          padding: 0;
          position: relative;
          cursor: pointer;
        }

        .gc-menu-toggle::before,
        .gc-menu-toggle::after {
          content: "";
          position: absolute;
          left: 0;
          width: 22px;
          border-top: 2px solid var(--gc-ink);
          transition: transform 0.2s ease, top 0.2s ease;
        }

        .gc-menu-toggle::before { top: 0; }
        .gc-menu-toggle::after { top: 16px; }

        .gc-site-header__inner.is-open {
          grid-template-rows: 64px auto auto;
          row-gap: 20px;
          padding-bottom: 20px;
        }

        /* keep logo left and burger right in row 1; nav/actions drop below */
        .gc-site-header__inner.is-open .gc-logo {
          grid-row: 1;
          grid-column: 1;
        }

        .gc-site-header__inner.is-open .gc-menu-toggle {
          grid-row: 1;
          grid-column: 2;
          justify-self: end;
          background-image: none;
        }

        .gc-site-header__inner.is-open .gc-menu-toggle::before {
          top: 8px;
          transform: rotate(45deg);
        }

        .gc-site-header__inner.is-open .gc-menu-toggle::after {
          top: 8px;
          transform: rotate(-45deg);
        }

        .gc-site-header__inner.is-open .gc-nav {
          grid-row: 2;
          grid-column: 1 / -1;
          display: flex;
          flex-direction: column;
          align-items: flex-start;
          gap: 16px;
        }

        .gc-site-header__inner.is-open .gc-header-actions {
          grid-row: 3;
          grid-column: 1 / -1;
          display: flex;
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <header class="gc-site-header">
      <div class="gc-container gc-site-header__inner">
        {% render 'genius-logo' %}
        <nav class="gc-nav" aria-label="{{ 'general.navigation.main' | t }}">
          <a href="{{ routes.all_products_collection_url }}">{{ 'general.navigation.roasts' | t }}</a>
          <a href="{{ routes.all_products_collection_url }}" {% if template.name == 'collection' %}aria-current="page"{% endif %}>{{ 'general.navigation.shop' | t }}</a>
        </nav>
        <div class="gc-header-actions">
          <a class="gc-header-account" href="{{ routes.account_url }}" aria-label="{{ 'general.navigation.account' | t }}">
            <svg class="gc-account-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 21c0-4 3.6-6.5 8-6.5s8 2.5 8 6.5"/>
            </svg>
          </a>
          <a class="gc-header-cart" href="{{ routes.cart_url }}" aria-label="{{ 'general.navigation.cart' | t }}{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}">
            <svg class="gc-cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <circle cx="9" cy="20" r="1.4"/>
              <circle cx="18" cy="20" r="1.4"/>
              <path d="M2 3h2.2l2.3 12.2a1.5 1.5 0 0 0 1.5 1.2h8.6a1.5 1.5 0 0 0 1.5-1.2L21 7H5.2"/>
            </svg>
            {% if cart.item_count > 0 %}<span class="gc-header-cart__count">{{ cart.item_count }}</span>{% endif %}
          </a>
          <a class="gc-button" href="{{ routes.all_products_collection_url }}">
            {{ 'general.navigation.order_now' | t }}
            {% render 'gc-arrow-icon' %}
          </a>
        </div>
        <button class="gc-menu-toggle" type="button" aria-expanded="false" aria-label="{{ 'general.navigation.open_menu' | t }}"></button>
      </div>
    </header>
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
    <script>
      // ponytail: plain class toggle for the mobile nav; no framework needed
      document.querySelector('.gc-menu-toggle')?.addEventListener('click', function () {
        var inner = this.closest('.gc-site-header__inner');
        var open = inner.classList.toggle('is-open');
        this.setAttribute('aria-expanded', open);
      });
    </script>
  </body>
</html>
